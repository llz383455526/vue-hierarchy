{
  "name": "vue-hierarchy",
  "displayName": "Vue Hierarchy",
  "description": "Display Vue component structure (Options API & Composition API / script setup) in a sidebar tree view with click-to-navigate support",
  "version": "1.0.0",
  "publisher": "vue-hierarchy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:vue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vue-hierarchy",
          "title": "Vue Hierarchy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vue-hierarchy": [
        {
          "id": "vueHierarchyView",
          "name": "Structure",
          "contextualTitle": "Vue Hierarchy"
        }
      ]
    },
    "commands": [
      {
        "command": "vueHierarchy.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "vueHierarchy.gotoLine",
        "title": "Go to Definition"
      },
      {
        "command": "vueHierarchy.gotoRef",
        "title": "Go to Reference",
        "icon": "$(references)"
      },
      {
        "command": "vueHierarchy.filterCategories",
        "title": "Filter Categories",
        "icon": "$(filter)"
      },
      {
        "command": "vueHierarchy.gotoMember",
        "title": "Go to Member",
        "icon": "$(search)"
      },
      {
        "command": "vueHierarchy.toggleCollapse",
        "title": "Toggle Expand/Collapse All",
        "icon": "$(fold)"
      },
      {
        "command": "vueHierarchy.focusCategory",
        "title": "Focus Category",
        "icon": "$(target)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vueHierarchy.filterCategories",
          "when": "view == vueHierarchyView",
          "group": "navigation"
        },
        {
          "command": "vueHierarchy.gotoMember",
          "when": "view == vueHierarchyView",
          "group": "navigation"
        },
        {
          "command": "vueHierarchy.focusCategory",
          "when": "view == vueHierarchyView",
          "group": "navigation"
        },
        {
          "command": "vueHierarchy.toggleCollapse",
          "when": "view == vueHierarchyView",
          "group": "navigation"
        },
        {
          "command": "vueHierarchy.refresh",
          "when": "view == vueHierarchyView",
          "group": "2_actions"
        }
      ],
      "view/item/context": [
        {
          "command": "vueHierarchy.gotoRef",
          "when": "view == vueHierarchyView && viewItem != template && viewItem != style && viewItem != lifecycle && viewItem != components && viewItem != directives && viewItem != mixins && viewItem != interface",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@vue/compiler-sfc": "^3.4.0"
  }
}